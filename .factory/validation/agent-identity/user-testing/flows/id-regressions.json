    {
      "id": "VAL-CROSS-005",
      "title": "Existing tier regression",
      "status": "pass",
      "steps": [
        {
          "action": "Validate free-tier share cap with assigned account",
          "expected": "Limit enforced at 5 total shares",
          "observed": "Baseline shares=1; additional attempts statuses 201,201,201,201,429 with SHARE_LIMIT on the 5th new attempt (6th would also be blocked)"
        },
        {
          "action": "Validate free-tier spike cap on namespaced share",
          "expected": "Limit enforced at 1000 spikes/share",
          "observed": "Share reached total_count=1000 with 201 responses; next write at total_count=1001 returned 429 SPIKE_LIMIT"
        },
        {
          "action": "Check checkout availability for Pro path",
          "expected": "Checkout endpoint available or fallback seeding used",
          "observed": "GET /billing/checkout and /billing/checkout?tier=pro both returned 500 Billing not configured"
        },
        {
          "action": "Apply allowed local D1 seed fallback for Pro and re-test limits",
          "expected": "After tier='pro', creation limits are no longer enforced",
          "observed": "D1 query shows tier free->pro; /me reports tier=pro; three share creates after free-limit all returned 201; spike write after prior SPIKE_LIMIT returned 201"
        }
      ],
      "evidence": {
