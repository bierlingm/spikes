    {
      "id": "VAL-UX-007",
      "title": "spikes delete <id> Command",
      "status": "pass",
      "steps": [
        {
          "action": "List initial spikes",
          "expected": "3 spikes displayed with IDs uxc1a111, uxc1b222, uxc1c333",
          "observed": "3 spikes displayed: uxc1a111 (unresolved), uxc1b222 (resolved ✓), uxc1c333 (unresolved)"
        },
        {
          "action": "Delete with full ID and --force",
          "command": "spikes delete uxc1c333-3333-3333-3333-333333333333 --force",
          "expected": "Spike deleted without confirmation prompt",
          "observed": "Output: 'Deleted spike uxc1c333-3333-3333-3333-333333333333.' with exit code 0"
        },
        {
          "action": "Verify deletion in list",
          "expected": "Only 2 spikes remain (uxc1a111, uxc1b222)",
          "observed": "List shows 2 spikes, uxc1c333 removed"
        },
        {
          "action": "Delete non-existent ID",
          "command": "spikes delete nonexistent-id-12345 --force",
          "expected": "Error with exit code 1",
          "observed": "Error: 'Spike not found: nonexistent-id-12345' with exit code 1"
        },
        {
          "action": "Delete with unique 4+ char prefix",
          "command": "spikes delete uxc1a --force",
          "expected": "Spike uxc1a111 deleted using prefix",
          "observed": "Output: 'Deleted spike uxc1a111-1111-1111-1111-111111111111.' with exit code 0"
        },
        {
          "action": "Test confirmation prompt (cancel)",
          "command": "spikes delete uxc1b222 (interactive)",
          "expected": "Prompt 'Delete spike ...? [y/N]' with cancellation on 'n'",
          "observed": "Prompt displayed: 'Delete spike 'uxc1b222' on page '/index.html'? [y/N]' - after typing 'n', output 'Cancelled.' and spike remains in list"
        },
        {
          "action": "Test confirmation prompt (confirm)",
          "command": "spikes delete uxc1b222 (interactive)",
          "expected": "Prompt with deletion on 'y'",
          "observed": "After typing 'y', output 'Deleted spike uxc1b222-2222-2222-2222-222222222222.' - list shows 'No spikes found.'"
        }
      ],
      "evidence": {
        "commands": [
          "spikes list",
          "spikes delete uxc1c333-3333-3333-3333-333333333333 --force",
          "spikes delete nonexistent-id-12345 --force (exit code 1)",
          "spikes delete uxc1a --force",
          "spikes delete uxc1b222 (interactive with 'n' -> cancelled)",
          "spikes delete uxc1b222 (interactive with 'y' -> deleted)"
        ],
        "terminalSnapshots": [
          "Delete spike 'uxc1b222' on page '/index.html'? [y/N] n\nCancelled.",
          "Delete spike 'uxc1b222' on page '/index.html'? [y/N] y\nDeleted spike uxc1b222-2222-2222-2222-222222222222."
        ],
        "jsonlBefore": "3 spikes: uxc1a111 (unresolved), uxc1b222 (resolved), uxc1c333 (unresolved)",
        "jsonlAfter": "0 spikes remaining after deletions"
      },
